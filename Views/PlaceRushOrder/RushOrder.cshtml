@model MediaStore.ViewModels.RushOrderForm
@{
    ViewData["Title"] = "RushOrder";
 } 
  
 <!-- Page Header -->
<div class="container-fluid page-header py-5">
    <h1 class="text-center text-white display-6">Checkout</h1>
</div>

<!-- Rush Order -->
<div class="container-fluid py-5">
    <div class="container py-5">
        <h1 class="mb-4">Additional Rush Order Info</h1>

        <form asp-action="RushOrder" method="post">
            <!-- Hiển thị lỗi toàn cục -->
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-5">
                <div class="col-12">

                    <!-- Delivery Time -->
                    <div class="form-group mb-3">
                        <label asp-for="DeliveryTime" class="form-label"></label>
                        <input asp-for="DeliveryTime" class="form-control" type="datetime-local" min="@ViewBag.MinDeliveryTime" max="@ViewBag.MaxDeliveryTime"/>
                        <span asp-validation-for="DeliveryTime" class="text-danger"></span>
                    </div>

                    <!-- Optional Instruction -->
                    <div class="form-group mb-3">
                        <label asp-for="Instruction" class="form-label">Instruction (optional)</label>
                        <textarea asp-for="Instruction" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Instruction" class="text-danger"></span>
                    </div>

                    <!-- Submit Button -->
                    <div class="row g-4 text-center align-items-center justify-content-center pt-4">
                        <div class="col-md-4 col-lg-2">
                            <button type="submit" class="btn border-secondary py-3 px-4 text-uppercase w-100 text-primary">
                                Submit
                            </button>
                        </div>
                    </div>

                </div>
            </div>
        </form>
    </div>
</div>