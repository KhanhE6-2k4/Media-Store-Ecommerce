@{
    Layout = "~/Views/Shared/_SignInLayout.cshtml";
    ViewData["Title"] = "Sign In";

}
<section class="ftco-section">
		<div class="container">
			<div class="row justify-content-center">
				<div class="col-md-6 text-center mb-5">
					<h2 class="heading-section">Sign In</h2>
				</div>
			</div>
			<div class="row justify-content-center">
				<div class="col-md-6 col-lg-4">
					<div class="login-wrap p-0">
		      	<h3 class="mb-4 text-center">Have an account?</h3>
		      	<form method="post" asp-action="SignIn" asp-controller="Account" class="signin-form" id="login-form">
		      		<div class="form-group">
		      			<input type="text" name="username" class="form-control" placeholder="Username" required>
		      		</div>
                    <div class="form-group">
                        <input id="password-field" name="password" type="password" class="form-control" placeholder="Password" required>
                        <span toggle="#password-field" class="fa fa-fw fa-eye field-icon toggle-password"></span>
                    </div>
                    <div class="form-group">
                        <button type="submit" class="form-control btn btn-primary submit px-3">Sign In</button>
                    </div>
                    @* <div class="form-group d-md-flex">
                        <div class="w-50">
                            <label class="checkbox-wrap checkbox-primary">Remember Me
                                <input type="checkbox" checked>
                                <span class="checkmark"></span>
                            </label>
                        </div>
                        <div class="w-50 text-md-right">
                            <a href="#" style="color: #fff">Forgot Password</a>
                        </div>
                    </div> *@
                    <div class="form-group">
		      			<input type="hidden" name="returnUrl" value="@Context.Request.Query["returnUrl"]" />
                        <input type="hidden" name="SignInAsGuest" id= "SignInAsGuest" value="false" />
                        @* <input type="hidden" name="wantToRegister" id="wantToRegister" value="false" /> *@
		      		</div>
	          </form>
                <a href="#" id="guestSignInButton">
                    <p class="w-100 text-center text-white">&mdash; Sign In As Guest &mdash;</p>
                </a>
                <a asp-controller="Account" asp-action="SignUp" id="RegisterButton">
                    <p class="w-100 text-center text-white">&mdash; Don't have an account? Sign up &mdash;</p>
                </a>
                @* <div class="social d-flex text-center">
                    <a href="#" class="px-2 py-2 mr-md-1 rounded"><span class="ion-logo-facebook mr-2"></span> Facebook</a>
                    <a href="#" class="px-2 py-2 ml-md-1 rounded"><span class="ion-logo-twitter mr-2"></span> Twitter</a>
                </div> *@
			</div>
		</div>
	</section>

@if (ViewBag.Error != null)
{
    <p style="color:red">@ViewBag.Error</p>
}
@if (TempData["Sign up success"] != null) {
    <p style="color:green">@TempData["Sign up success"]</p>
}

<script>
    document.getElementById('guestSignInButton').addEventListener('click', function (e) {
        e.preventDefault();

        document.getElementById('SignInAsGuest').value = "true";
        document.getElementById('login-form').submit();
    })
</script>
