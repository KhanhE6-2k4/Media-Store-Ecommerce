@model IEnumerable<MediaStore.ViewModels.CartItem>
@{
    ViewData["Title"] = "Index";
    var cartError = TempData["CartError"] as string;
}
    <!-- Single Page Header start -->
    <div class="container-fluid page-header py-5">
        <h1 class="text-center text-white display-6">Cart</h1>
        <ol class="breadcrumb justify-content-center mb-0">
            <li class="breadcrumb-item"><a href="/Home/Index">Home</a></li>
            <li class="breadcrumb-item active text-white">Cart</li> 
        </ol>
    </div>
    <!-- Single Page Header End -->


    <!-- Cart Page Start -->
    <div class="container-fluid py-5">
        <div class="container py-5">
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                        <th scope="col">Products</th>
                        <th scope="col">Name</th>
                        <th scope="col">Price</th>
                        <th scope="col">Quantity</th>
                        <th scope="col">Total</th>
                        <th scope="col">Handle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var item in Model)
                        {
                        <tr>
                            <th scope="row">
                                <div class="d-flex align-items-center">
                                    <img src="~/img/media_img/@item.ImageUrl" class="img-fluid me-5" style="width: 80px; height: 100px;" alt="">
                                </div>
                            </th>
                            <td>
                                <p class="mb-0 mt-4" style="width: 300px">@item.Title</p>
                            </td>
                            <td>
                                <p class="mb-0 mt-4">@($"{item.Price.ToString("#,##0")} VND")</p>
                            </td>
                            <td>
                                <div class="input-group quantity mt-4" style="width: 100px;">
                                    <div class="input-group-btn">
                                        <button class="btn btn-sm btn-minus rounded-circle bg-light border" data-id="@item.Id" data-action="minus">
                                            <i class="fa fa-minus"></i>
                                        </button>
                                    </div>
                                    <input type="text"
                                        id="qty-@item.Id" 
                                        class="form-control form-control-sm text-center border-0" 
                                        value="@item.Qty" 
                                        data-id="@item.Id"
                                        data-max="@item.TotalQuantity"
                                        onchange="validateQty(@item.Id)"
                                        onblur="submitQty(@item.Id)">
                                    <div class="input-group-btn">
                                        <button class="btn btn-sm btn-plus rounded-circle bg-light border" data-id="@item.Id" data-action="plus">
                                            <i class="fa fa-plus"></i>
                                        </button>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <p data-id="cart-product-amount-@item.Id" class="mb-0 mt-4">@($"{item.Amount.ToString("#,##0")} VND")</p>
                            </td>
                            <td>
                                <button class="btn btn-md btn-remove rounded-circle bg-light border mt-4" data-id="@item.Id">
                                    <i class="fa fa-times text-danger"></i>
                                </button>
                            </td>
                        
                        </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="mt-5">
                <input type="text" class="border-0 border-bottom rounded me-5 py-3 mb-4" placeholder="Coupon Code">
                <button class="btn border-secondary rounded-pill px-4 py-3 text-primary" type="button">Apply Coupon</button>
            </div>
            <div class="row g-4 justify-content-end">
                <div class="col-8"></div>
                <div class="col-sm-8 col-md-7 col-lg-6 col-xl-4">
                    <div class="bg-light rounded">
                        <div class="p-4">
                            <h1 class="display-6 mb-4">Cart</h1>
                            @* <span class="fw-normal">Total</span> *@
                            @* <div class="d-flex justify-content-between mb-4">
                                <h5 class="mb-0 me-4">Total  Amount: </h5>
                                <p id="cart-total-amount" class="mb-0">0</p>
                            </div> *@
                            @* <div class="d-flex justify-content-between">
                                <h5 class="mb-0 me-4">Shipping</h5>
                                <div class="">
                                    <p class="mb-0">Flat rate: $1.00</p>
                                </div>
                            </div>
                            <p class="mb-0 text-end">Shipping to HCM.</p> *@
                        </div>
                        <div class="py-4 mb-4 border-top border-bottom d-flex justify-content-between">
                            <h5 class="mb-0 ps-4 me-4">Total</h5>
                            <p id="cart-total-amount" class="mb-0 pe-4"> </p>
                        </div>
                        <a asp-action="Checkout" asp-controller="Cart">
                        <button class="btn border-secondary rounded-pill px-4 py-3 text-primary text-uppercase mb-4 ms-4" type="button">Proceed Checkout</button>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Cart Page End -->
@if (!string.IsNullOrEmpty(cartError))
{
    <div id="cartErrorPopup" class="modal fade" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" style="color: #212529;">Cart Error</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>@cartError</p>
                </div>
            </div>

        </div> 

    </div>
    <script>
    window.onload = function() {
        var myModal = new bootstrap.Modal(document.getElementById('cartErrorPopup'));
        myModal.show();
    };
    </script>
}
