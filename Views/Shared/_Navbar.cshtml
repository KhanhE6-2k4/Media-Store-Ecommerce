 <!-- Navbar start -->
<div class="container-fluid fixed-top">
    <div class="container topbar bg-primary d-none d-lg-block">
        <div class="d-flex justify-content-between">
            <div class="top-info ps-2">
                <small class="me-3"><i class="fas fa-map-marker-alt me-2 text-secondary"></i> <a href="#" class="text-white">19 Trần Đại Nghĩa, Hà Nội</a></small>
                <small class="me-3"><i class="fas fa-envelope me-2 text-secondary"></i><a href="#" class="text-white">Email@Example.com</a></small>
            </div>
            <div class="top-link pe-2">
                <a href="#" class="text-white"><small class="text-white mx-2">Privacy Policy</small>/</a>
                <a href="#" class="text-white"><small class="text-white mx-2">Terms of Use</small>/</a>
                <a href="#" class="text-white"><small class="text-white ms-2">Sales and Refunds</small></a>
            </div>
        </div>
    </div>
    <div class="container px-0">
        <nav class="navbar navbar-light bg-white navbar-expand-xl">
            <a href="#" class="navbar-brand"><h1 class="text-primary display-6">Media store</h1></a> 
            <!-- Can sua o day -->
            <button class="navbar-toggler py-2 px-3" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="fa fa-bars text-primary"></span>
            </button>
            <div class="collapse navbar-collapse bg-white" id="navbarCollapse">
                <div class="navbar-nav mx-auto">
                    @* <a href="index.html" class="nav-item nav-link active">Home</a>  *@
                    @* <a href="shop.html" class="nav-item nav-link">Shop</a> *@
                    <a asp-controller="Home" asp-action="Index" 
                       class="nav-item nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Home" ? "active" : "")">Home</a>
                    <a asp-controller="Product" asp-action="Index" 
                       class="nav-item nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Product" ? "active" : "")">Shop</a>
                    <a asp-controller="Cart" asp-action="Index"
					   class="nav-item nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Cart" ? "active" : "")">Cart</a>
                    <a href="#" id="orderLink"
					   class="nav-item nav-link @(ViewContext.RouteData.Values["controller"].ToString() == "Order" ? "active" : "")">Order</a>
                </div>
                <div class="d-flex m-3 me-0">
                    <button class="btn-search btn border border-secondary btn-md-square rounded-circle bg-white me-4" data-bs-toggle="modal" data-bs-target="#searchModal"><i class="fas fa-search text-primary"></i></button>
                    <a href="/Cart/Index" class="position-relative me-4 my-auto">
                        <i class="fa fa-shopping-bag fa-2x"></i>
                        <span id="cart-count" class="position-absolute bg-secondary rounded-circle d-flex align-items-center justify-content-center text-dark px-1" style="top: -5px; left: 15px; height: 20px; min-width: 20px;">0</span>
                    </a>
                    @* <a href="#" class="my-auto">
                        <i class="fas fa-user fa-2x"></i>
                    </a> *@
                    <div class="dropdown d-flex align-items-center">
                        <a href="#" class="dropdown-toggle text-decoration-none" data-bs-toggle="dropdown">
                            <i class="fas fa-user fa-2x"></i>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">

                            @if (User.Identity?.IsAuthenticated == true && !User.IsInRole("Guest") && !User.IsInRole("Admin"))
                            {
                                @* <li>
                                    <a class="dropdown-item"
                                    asp-controller="Account"
                                    asp-action="Profile">
                                    Profile
                                    </a>
                                </li> *@

                                <li>
                                    <a class="dropdown-item"
                                    asp-controller="Account"
                                    asp-action="Logout">
                                    Logout
                                    </a>
                                </li>
                            }
                            else
                            {
                                <li>
                                    <a class="dropdown-item"
                                    asp-controller="Account"
                                    asp-action="SignIn">
                                    Sign In
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item"
                                    asp-controller="Account"
                                    asp-action="SignUp">
                                    Sign Up
                                    </a>
                                </li>
                            }

                        </ul>
                    </div>

                </div>
            </div>
        </nav>
    </div>
</div>
<!-- Navbar End -->

<!-- Modal -->
<div class="modal fade" id="loginModal" tabindex="-1" aria-labelledby="loginModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h1 class="modal-title fs-5" id="loginModalLabel">Sign In Required</h1>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        You need to sign in to access the Order section. Would you like to sign in now?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary" id="confirmLoginBtn">Sign In</button>
      </div>
    </div>
  </div>
</div>

<script>
    document.getElementById('orderLink').addEventListener('click', async function(e) {
        e.preventDefault();

        try {
            // Gọi API hoặc fetch trang Order (ví dụ lấy nội dung qua AJAX)
            let response = await fetch('/Order/Index', {
                credentials: 'include'  // gửi cookie
            });

            if (response.status === 401 || response.status === 403) {
                // Hiện modal login
                const modal = new bootstrap.Modal(document.getElementById('loginModal'));
                modal.show();
                document.getElementById('confirmLoginBtn').onclick = () => {
                    const returnUrl = encodeURIComponent('/Order/Index');
                    window.location.href = `/Account/SignIn?returnUrl=${returnUrl}`;
                };
            } else if (response.ok) {
                // Nếu được phép truy cập, chuyển trang
                window.location.href = '/Order/Index';
            } else {
                alert('Lỗi không xác định');
            }
        } catch (error) {
            console.error(error);
        }
    });

</script>

