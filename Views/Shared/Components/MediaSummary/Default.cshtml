@model IEnumerable<MediaStore.ViewModels.MediaSummaryItem>

<div class="col-lg-12">
    <div class="mb-3">
        <h4>Categories</h4>
        <ul class="list-unstyled product-categorie">
        @foreach(var item in Model) {
            <li>
                <div class="d-flex justify-content-between product-name">
                    <a asp-controller="Product" asp-action="Index" asp-route-TypeName=@item.TypeName>
                        <i></i>@item.TypeName
                    </a>
                    <span>(@item.Count)</span>
                </div>
            </li>
        }
        </ul>
    </div>
</div>